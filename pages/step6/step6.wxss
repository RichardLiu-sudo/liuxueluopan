.container {
  padding: 32rpx;
  background: #F7F6F3;
  min-height: 100vh;
  animation: fadeInUp 300ms ease-out;
}

.step-header {
  text-align: center;
  margin-bottom: 20rpx;
}
.step-badge {
  font-size: 22rpx;
  color: #FFFFFF;
  background: #3A5078;
  padding: 4rpx 20rpx;
  border-radius: 8rpx;
  letter-spacing: 1rpx;
}
.step-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1B2A4A;
  display: block;
  margin-top: 16rpx;
}
.step-desc {
  font-size: 24rpx;
  color: #8A98AE;
  display: block;
  margin-top: 8rpx;
}

.form {
  background: #FFFFFF;
  border-radius: 8rpx;
  padding: 20rpx 32rpx;
  margin-top: 20rpx;
  box-shadow: 0 1rpx 4rpx rgba(27,42,74,0.03);
}
.form-group {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E8E5DF;
}
.form-group:last-child { border-bottom: none; }
.label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1B2A4A;
  display: block;
  margin-bottom: 12rpx;
}
.picker {
  height: 72rpx;
  line-height: 72rpx;
  background: #F7F6F3;
  border: 1rpx solid #E8E5DF;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1B2A4A;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.picker::after {
  content: '\25BC';
  font-size: 20rpx;
  color: #5A6A82;
  flex-shrink: 0;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.tag {
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 20rpx;
  background: #F7F6F3;
  border: 1rpx solid #E8E5DF;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #5A6A82;
}
.tag-active {
  background: #EDECEA;
  border-color: #3A5078;
  color: #1B2A4A;
  font-weight: 500;
}
