<view class="container">
  <view class="step-progress-bar">
    <text class="step-progress-label">第 2/5 步</text>
    <view class="step-progress-grid">
      <view class="step-progress-cell cell-done"></view>
      <view class="step-progress-cell cell-active"></view>
      <view class="step-progress-cell"></view>
      <view class="step-progress-cell"></view>
      <view class="step-progress-cell"></view>
    </view>
  </view>

  <view class="step-header">
    <text class="step-badge">Step 2</text>
    <text class="step-title">专业专注度与学术好奇心</text>
    <text class="step-desc">满分 30 分 — 招生官想看你怎么用工具去探索世界</text>
  </view>

  <view class="step-indicator">
    <view class="step-dot done"></view>
    <view class="step-dot active"></view>
    <view class="step-dot"></view>
    <view class="step-dot"></view>
    <view class="step-dot"></view>
  </view>

  <view class="form">
    <view class="form-group">
      <text class="label">意向专业方向（多选）</text>
      <view class="tag-grid">
        <view class="tag {{item.checked ? 'tag-active' : ''}}" wx:for="{{majorOptions}}" wx:key="value" data-index="{{index}}" bindtap="onMajorToggle">{{item.label}}</view>
      </view>
    </view>

    <view class="form-group">
      <text class="label">科研 / 夏校经历</text>
      <picker mode="selector" range="{{researchOptions}}" value="{{researchIndex}}" bindchange="onResearchChange">
        <view class="picker">
          <text class="{{research ? '' : 'picker-placeholder'}}">{{research || '请选择科研经历'}}</text>
        </view>
      </picker>
    </view>

    <view class="form-group">
      <text class="label">自主探索证明（多选）</text>
      <view class="tag-grid">
        <view class="tag {{item.checked ? 'tag-active' : ''}}" wx:for="{{exploreOptions}}" wx:key="value" data-index="{{index}}" bindtap="onExploreToggle">{{item.label}}</view>
      </view>
    </view>

    <view class="form-group">
      <text class="label">专业相关推荐信</text>
      <picker mode="selector" range="{{recOptions}}" value="{{profRecIndex}}" bindchange="onProfRecChange">
        <view class="picker">
          <text class="{{profRec ? '' : 'picker-placeholder'}}">{{profRec || '请选择推荐信情况'}}</text>
        </view>
      </picker>
    </view>

    <view class="form-group">
      <text class="label">深度自述（选填，最多100字）</text>
      <textarea class="textarea-field" placeholder="描述一个你出于好奇主动探索的例子（比如：因为好奇AI怎么画画，我自学了PyTorch并训练了一个小模型...）" maxlength="100" value="{{deepNarrative}}" bindinput="onNarrativeInput" auto-height />
    </view>
  </view>

  <text class="step-why-hint">标化和语言只是工具，招生官要看你怎么用这些工具去探索世界。</text>

  <button class="btn-primary" bindtap="submitStep">下一步</button>
</view>
