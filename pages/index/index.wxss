.container {
  padding: 32rpx;
  min-height: 100vh;
  background: #F7F6F3;
}

/* ===== Hero ===== */
.hero {
  text-align: center;
  padding: 100rpx 0 60rpx;
}
.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #1B2A4A;
  display: block;
  letter-spacing: 4rpx;
}
.subtitle {
  font-size: 26rpx;
  color: #C9A96E;
  display: block;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

/* ===== 步骤概览 ===== */
.steps-overview {
  background: #FFFFFF;
  border-radius: 8rpx;
  padding: 8rpx 32rpx;
  margin: 20rpx 0;
  box-shadow: 0 1rpx 4rpx rgba(27,42,74,0.04);
}
.step-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E8E5DF;
}
.step-row:last-child { border-bottom: none; }

.step-num {
  width: 44rpx;
  height: 44rpx;
  line-height: 42rpx;
  text-align: center;
  border: 2rpx solid #C9A96E;
  color: #C9A96E;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #FFFFFF;
}
.step-name {
  font-size: 28rpx;
  color: #1B2A4A;
  display: block;
}

/* ===== Tips ===== */
.tips {
  text-align: center;
  padding: 24rpx 0;
  margin: 20rpx 0;
}
.tips-highlight {
  background: linear-gradient(135deg, rgba(27,42,74,0.08), rgba(27,42,74,0.03));
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(27,42,74,0.06);
}
.tips-highlight-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1B2A4A;
  display: block;
  letter-spacing: 1rpx;
}

/* ===== 价值描述条 ===== */
.value-strip {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 0 4rpx;
}
.value-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
  padding: 16rpx 8rpx;
  box-shadow: 0 1rpx 4rpx rgba(27,42,74,0.03);
}
.value-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}
.value-text {
  font-size: 20rpx;
  color: #3A5078;
  font-weight: 500;
  white-space: nowrap;
}
